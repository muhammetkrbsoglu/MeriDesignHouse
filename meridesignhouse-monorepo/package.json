{
  "name": "meridesignhouse-monorepo",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "storybook": "turbo run storybook --filter=frontend",
    "build-storybook": "turbo run build-storybook --filter=frontend"
  },
  "devDependencies": {
    "turbo": "^2.0.7",
    "typescript": "^5.7.2"
  }
}

