# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (ignore all nested)
node_modules/
**/node_modules/**

# next.js
/.next/
/out/

# production
/build
**/dist/**

# lockfiles generated in sub-packages by pnpm
**/pnpm-lock.yaml

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*storybook.log
storybook-static
